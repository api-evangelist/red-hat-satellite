        },
        "ip": {
          "@id": "satellite:ipv4Address",
          "@type": "xsd:string"
        },
        "ip6": {
          "@id": "satellite:ipv6Address",
          "@type": "xsd:string"
        },
        "type": {
          "@id": "satellite:interfaceType",
          "@type": "xsd:string"
        },
        "name": {
          "@id": "schema:name",
          "@type": "xsd:string"
        },
        "identifier": {
          "@id": "satellite:deviceIdentifier",
          "@type": "xsd:string"
        },
