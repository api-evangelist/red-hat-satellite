        },
        "name": {
          "@id": "schema:name",
          "@type": "xsd:string"
        },
        "label": {
          "@id": "satellite:label",
          "@type": "xsd:string"
        },
        "title": {
          "@id": "satellite:title",
          "@type": "xsd:string"
        },
        "description": {
          "@id": "schema:description",
          "@type": "xsd:string"
        },
