        },
        "label": {
          "@id": "katello:label",
          "@type": "xsd:string"
        },
        "description": {
          "@id": "schema:description",
          "@type": "xsd:string"
        },
        "organization_id": {
          "@id": "satellite:organizationId",
          "@type": "xsd:integer"
        },
        "library": {
          "@id": "katello:isLibrary",
          "@type": "xsd:boolean"
        },
        "prior": {
          "@id": "katello:priorEnvironment",
          "@type": "@id"
        },
        "successor": {
          "@id": "katello:successorEnvironment",
